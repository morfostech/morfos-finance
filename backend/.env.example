# --- API ---
PORT=8080
# Origens permitidas para CORS (frontend Vite em dev)
CORS_ORIGINS=http://localhost:5173

# --- Banco ---
# Local (docker-compose) ou string do Supabase/Neon
DATABASE_URL=postgres://morfos:morfos@localhost:5432/morfos_finance?sslmode=disable

# --- Auth ---
# Troque por um segredo longo e aleatório em produção
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio
# Aceita duração Go (ex.: 24h, 30m) ou segundos
JWT_TTL=24h

# --- Seed do admin inicial (usado por cmd/seed) ---
SEED_ADMIN_NOME=Admin Morfos
SEED_ADMIN_EMAIL=admin@morfostech.com.br
SEED_ADMIN_SENHA=troque-esta-senha

# --- Storage de anexos ---
# Sem as variáveis S3 abaixo, os arquivos vão para disco local em UPLOAD_DIR
# (servidos pela API em /uploads). Defina S3_ENDPOINT + S3_BUCKET para usar
# Cloudflare R2 (ou qualquer S3-compatible: MinIO, Supabase Storage).
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_BUCKET=morfos-finance
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_PUBLIC_BASE_URL=https://cdn.seudominio.com   # opcional (URLs públicas)
